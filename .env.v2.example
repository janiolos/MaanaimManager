# =========================
# Maanaim Manager v2 (FastAPI + React)
# =========================
PROJECT_NAME=maanaim
HOST_PORT=8090
TIMEZONE=America/Sao_Paulo
APP_ENV=prod

# =========================
# Banco PostgreSQL
# =========================
# Opção 1: Usar o Postgres embutido no Docker (default)
POSTGRES_DB=eventa
POSTGRES_USER=eventa
POSTGRES_PASSWORD=change-me-strong-password

# Opção 2: Apontar para o Postgres Django existente (descomente)
# DATABASE_URL=postgresql+asyncpg://eventa:eventa@host.docker.internal:5432/maanaim_db
# Nota: host.docker.internal funciona no Docker Desktop (Mac/Windows)
# No Linux, use o IP da máquina ou crie a rede Docker manualmente

# =========================
# JWT
# =========================
# Gere com: python -c "import secrets;print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-please-generate-a-32-byte-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# CORS
# =========================
BACKEND_CORS_ORIGINS=http://localhost:8090
