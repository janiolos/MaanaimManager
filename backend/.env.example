PROJECT_NAME=MaanaimManager
ENVIRONMENT=dev
TIMEZONE=America/Sao_Paulo

# =========================
# Banco PostgreSQL
# =========================
DATABASE_URL=postgresql+asyncpg://eventa:eventa@localhost:5432/eventa

# =========================
# JWT / Auth
# =========================
JWT_SECRET_KEY=changeme-please-generate-a-32-byte-random-string
